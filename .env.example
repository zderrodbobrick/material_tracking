# RFID Tracking System Configuration
# Copy this file to .env and fill in your values

# Listener Settings
LISTENER_HOST=0.0.0.0
LISTENER_PORT=5000

# Database (path relative to project root, not process cwd)
DB_PATH=database/rfid_reads.db

# Antenna Configuration
ENTRY_ANTENNA=1
EXIT_ANTENNA=2

# RSSI Filter (signal strength threshold)
# Valid reads must satisfy: RSSI_MIN <= rssi <= 0
# Lower = greater range: -40 (touch), -65 (few inches), -70 (room scale)
RSSI_MIN=-65

# Temporal filtering: ignore stray reads - require N sustained reads to start session
# Higher = more selective against distant tags, but slower to detect valid passes
MIN_READS_FOR_SESSION=3

# EPC whitelist filter - only process tags containing this hex pattern
# "IBUS" = 49425553 in hex. Leave empty to accept all EPCs.
EPC_FILTER_PATTERN=49425553

# Session Management (Fast-Moving Tags Optimized)
# Drop duplicate reads within this many seconds (0.05 = 50ms for high resolution)
RAW_THROTTLE_SEC=0.05

# Auto-close idle sessions after this many seconds (2s for quick operators)
IDLE_TIMEOUT_SEC=2.0

# Abandon sessions that never reach exit antenna (5s for faster cleanup)
ABANDON_TIMEOUT_SEC=5.0

# Background sweeper interval (0.5s for more frequent cleanup)
SWEEP_INTERVAL_SEC=0.5

# Database pruning
RAW_MAX_ROWS=20000
PRUNE_EVERY_N_INSERTS=200

# Printer Configuration
PRINTER_IP=10.25.100.157
PRINTER_PORT=9100

# Sewio RTLS (factory LAN only — server at 10.25.80.13)
ENABLE_LIVE_INGESTION=false
SEWIO_WS_HOST=wss://10.25.80.13
SEWIO_API_KEY=
# Optional: subscribe to one tag only; leave empty for all feeds
SEWIO_FEED_ID=
# Optional extra zone IDs for this station (primary map: RTLS/zoneMappings.json)
SEWIO_STATION_ZONE_IDS=
SEWIO_LIVE_OFFSET_HOURS=0
SEWIO_VERIFY_SSL=false
