# RFID Tracking System Configuration
# Copy this file to .env and fill in your values

# Listener Settings
LISTENER_HOST=0.0.0.0
LISTENER_PORT=5000
# Optional: override the IP shown for reader HTTP POST config (e.g. 10.25.200.89)
# LISTENER_ADVERTISE_IP=10.25.200.89

# Database (path relative to project root, not process cwd)
DB_PATH=database/rfid_reads.db

# Antenna Configuration
ENTRY_ANTENNA=1
EXIT_ANTENNA=2
THIRD_ANTENNA=3
THIRD_ANTENNA_NAME=Insert Station
INSERT_STATION_NAME=Insert Station

# RSSI Filter (signal strength threshold)
# Valid reads must satisfy: RSSI_MIN <= rssi <= 0
# Lower = greater range: -40 (touch), -65 (few inches), -70 (room scale)
RSSI_MIN=-65

# Temporal filtering: ignore stray reads - require N sustained reads to start session
# Higher = more selective against distant tags, but slower to detect valid passes
MIN_READS_FOR_SESSION=3

# EPC whitelist filter - matched against decoded ASCII EPC (e.g. 1S170462064)
# Use .* to accept all known type-code tags. Old hex "49425553" does NOT work here.
EPC_FILTER_PATTERN=.*

# Session Management (Fast-Moving Tags Optimized)
# Drop duplicate reads within this many seconds (0.05 = 50ms for high resolution)
RAW_THROTTLE_SEC=0.05

# Auto-close idle sessions after this many seconds (2s for quick operators)
IDLE_TIMEOUT_SEC=2.0

# Abandon sessions that never complete the 1→2→3 path (5s for faster cleanup)
ABANDON_TIMEOUT_SEC=5.0

# Gannomat sessions no longer auto-close after the last antenna-2 read.
# They stay open until antenna 3 confirms arrival at Insert Station.
# EXIT_IDLE_TIMEOUT_SEC is deprecated (kept at 0).

# Background sweeper interval (0.5s for more frequent cleanup)
SWEEP_INTERVAL_SEC=0.5

# Database pruning
RAW_MAX_ROWS=20000
PRUNE_EVERY_N_INSERTS=200

# Printer Configuration
PRINTER_IP=10.25.100.157
PRINTER_PORT=9100

# Sewio RTLS (factory LAN only — server at 10.25.80.13)
ENABLE_LIVE_INGESTION=false
SEWIO_WS_HOST=wss://10.25.80.13
SEWIO_API_KEY=
# Optional: subscribe to one tag only; leave empty for all feeds
SEWIO_FEED_ID=
RTLS_TEST_FEED_ID=35
# Optional extra zone IDs for this station (primary map: RTLS/zoneMappings.json)
SEWIO_STATION_ZONE_IDS=
SEWIO_LIVE_OFFSET_HOURS=0
SEWIO_VERIFY_SSL=false
RTLS_OPERATOR_CONFIRM_SECS=10

# Floor plan overlay — edit these, then: cd dashboard && npm run build && hard-refresh browser
# Sewio (meters) at the anchor point on the floor (white rectangle corner = 7, 2.5)
VITE_FLOOR_PLAN_ORIGIN_X=7
VITE_FLOOR_PLAN_ORIGIN_Y=2.5
# Pixel position of that anchor on floor_plan.png (958×575 image)
VITE_FLOOR_PLAN_PIXEL_X=131
VITE_FLOOR_PLAN_PIXEL_Y=81
# Pixels per meter — increase if dots are too close; decrease if too spread out
VITE_FLOOR_PLAN_SCALE=18
